-- ===========================================================================
-- Mod Overrides — enable and configure Workshop mods.
-- Mod 覆盖配置 — 启用并配置工坊 mod。
--
-- Use this file to enable and configure your mods. A mod only takes effect
-- in the game if you set "enabled=true".
-- 用此文件启用和配置 mod。只有设置 "enabled=true" 后 mod 才会在游戏中生效。
--
-- During container startup this file is automatically copied to both Master/
-- and Caves/ shard folders. What is configured here applies to both shards.
-- 容器启动时，此文件自动复制到 Master/ 和 Caves/ 分片目录，
-- 此处配置会同时应用于两个分片。
--
-- See the example below / 参考下方示例：
-- ===========================================================================

return {
  -- ["workshop-000000000"]={
  --   configuration_options={
  --     ["CustomModSetting"]="value"
  --   },
  --   enabled=true
  -- },

  -- Extra Equip Slots — adds backpack and amulet slots
  -- 额外装备槽 — 添加背包和护符槽位
  -- https://steamcommunity.com/sharedfiles/filedetails/?id=375850593
  ["workshop-375850593"]={ configuration_options={  }, enabled=true },

  -- Health Info — shows exact health values on creatures
  -- 生物血量显示 — 显示生物精确血量数值
  -- https://steamcommunity.com/sharedfiles/filedetails/?id=375859599
  ["workshop-375859599"]={
    configuration_options={
      divider=5,
      random_health_value=0,
      random_range=0,
      show_type=0,
      unknwon_prefabs=1,
      use_blacklist=true
    },
    enabled=true
  },

  -- Global Positions — shows player and fire icons on the minimap globally
  -- 全球定位 — 在小地图上全局显示玩家和篝火图标
  -- https://steamcommunity.com/sharedfiles/filedetails/?id=378160973
  ["workshop-378160973"]={
    configuration_options={
      ENABLEPINGS=true,
      FIREOPTIONS=2,
      OVERRIDEMODE=false,
      SHAREMINIMAPPROGRESS=true,
      SHOWFIREICONS=true,
      SHOWPLAYERICONS=true,
      SHOWPLAYERSOPTIONS=2
    },
    enabled=true
  },

  -- Food Values - Item Tooltips — displays hunger, health, sanity, spoilage
  -- 食物属性 - 物品提示 — 显示饥饿值、生命值、理智值、保质期等信息
  -- https://steamcommunity.com/sharedfiles/filedetails/?id=458940297
  ["workshop-458940297"]={
    configuration_options={
      DFV_ClientPrediction="default",
      DFV_FueledSettings="default",
      DFV_Language="EN",
      DFV_MinimalMode="default",
      DFV_PercentReplace="default",
      DFV_ShowACondition="default",
      DFV_ShowADefence="default",
      DFV_ShowAType="default",
      DFV_ShowDamage="default",
      DFV_ShowFireTime="default",
      DFV_ShowInsulation="default",
      DFV_ShowTemperature="default",
      DFV_ShowUses="default"
    },
    enabled=true
  },
}
