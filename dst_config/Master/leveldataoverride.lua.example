-- ===========================================================================
-- World generation + customization for the MASTER (forest) shard.
--
-- This is a Lua table the server reads to build and tune the world. Don't edit
-- it by hand unless you know what you want -- the easy way to produce one is the
-- in-game "Host Game" screen: customize the world there, host once, then copy the
-- generated leveldataoverride.lua out of the save. Key fields:
--   id / location / name -> world identity ("forest" here; "cave" for caves)
--   world_size           -> "default" | "small" | "medium" | "large" | "huge"
--   overrides            -> the big table below: one entry per setting, e.g.
--                           creatures, resources, seasons, day length.
--
-- Most overrides take a frequency word: "default" | "never" | "rare" |
-- "uncommon" | "often" | "mostly" | "always" (some accept their own values).
-- Anything left as "default" uses the vanilla setting. Both shards must keep
-- required_prefabs = { "multiplayer_portal" } so players can travel between them.
-- ===========================================================================
return {
  desc="The standard Don't Starve experience.",
  hideminimap=false,
  id="SURVIVAL_TOGETHER",
