# ===========================================================================
# Environment overrides for docker-compose.yml.
# docker-compose.yml 的环境变量覆盖。
#
# Copy this file to ".env" (setup.sh does it for you) and edit as needed.
# 复制此文件为 ".env"（setup.sh 会执行此操作）并按需编辑。
#
# docker compose reads ".env" automatically; every value here has a built-in
# fallback, so you can delete any line you don't want to change.
# docker compose 自动读取 ".env"；每个值均有内建回退值，
# 可以删除不需要修改的行。
# ===========================================================================

# --- Master shard (surface / forest) ---
# --- 主世界（地表/森林）---
MASTER_NAME=dst_master   # container name shown by `docker ps` / `docker ps` 显示的容器名
MASTER_PORT=11999        # UDP port published on the host for the master shard / 主世界在主机发布的 UDP 端口

# --- Caves shard (underground) ---
# --- 洞穴世界（地下）---
CAVES_NAME=dst_caves     # container name shown by `docker ps` / `docker ps` 显示的容器名
CAVES_PORT=11998         # UDP port published on the host for the caves shard / 洞穴世界在主机发布的 UDP 端口
