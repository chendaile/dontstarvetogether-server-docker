# Optional overrides for docker-compose.yml.
# Copy this file to ".env" (setup.sh does it for you) and edit as needed.
# docker compose reads ".env" automatically; every value here has a built-in
# fallback, so you can delete any line you don't want to change.

# --- Master shard (surface / forest) ---
MASTER_NAME=dst_master   # container name shown by `docker ps`
MASTER_PORT=11999        # UDP port published on the host for the master shard

# --- Caves shard (underground) ---
CAVES_NAME=dst_caves     # container name shown by `docker ps`
CAVES_PORT=11998         # UDP port published on the host for the caves shard
